// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Direct connection for migrations (bypasses pooler)
}

// ══════════════════════════════════════════════════════════════════
// ENUMS — Type-safe status, role, stage values
// ══════════════════════════════════════════════════════════════════

enum DealStage {
  LEAD
  MEETING
  BOOKING
  DEPOSIT
  CONTRACT
  COMPLETED
  CANCELLED
}

enum LeadSource {
  FACEBOOK_ADS
  GOOGLE_ADS
  HOTLINE
  REFERRAL
  WALK_IN
  WEBSITE
  SELF_GEN
  MARKETING
}

enum PropertyUnitStatus {
  AVAILABLE
  BOOKED
  LOCKED
  PENDING_DEPOSIT
  DEPOSIT
  SOLD
  COMPLETED
}

enum DebtType {
  RECEIVABLE_CUSTOMER
  RECEIVABLE_DEVELOPER
  PAYABLE_STAFF
}

enum ContractType {
  PROBATION
  DEFINITE
  INDEFINITE
  FREELANCE
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  DAY_OFF
}

enum AppointmentType {
  MEETING
  SITE_VISIT
  FOLLOW_UP
  SIGNING
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ══════════════════════════════════════════════════════════════════
// AUTH
// ══════════════════════════════════════════════════════════════════
model User {
  id         String     @id @default(uuid(7))
  email      String     @unique
  name       String
  password   String
  role       String     @default("employee") // admin, hr, employee
  department String? // SALES, MARKETING, HR, FINANCE, OPS
  salesRole  String?    @map("sales_role")
  teamId     String?    @map("team_id")
  team       SalesTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  notifications     Notification[]
  salesStaffProfile SalesStaff?

  @@map("users")
}

// Refresh Token — dùng cho logout thực sự và token revocation
// Short-lived access token (1h) + long-lived refresh token (30d)
model RefreshToken {
  id         String    @id @default(uuid(7))
  token      String    @unique
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  deviceInfo String?   @map("device_info")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ══════════════════════════════════════════════════════════════════
// EXEC PLANNING (port from GAS Service_ExecPlanning.js)
// ══════════════════════════════════════════════════════════════════
model PlanScenarioLog {
  id            String    @id @default(uuid(7))
  planId        String    @map("plan_id")
  moduleKey     String    @default("EXEC") @map("module_key")
  scenario      String
  year          Int
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @map("created_by")
  schemaVersion String    @default("1") @map("schema_version")
  deletedAt     DateTime? @map("deleted_at")
  rawJson       Json?     @map("raw_json")
  note          String?

  @@index([planId])
  @@index([year, scenario])
  @@index([createdAt(sort: Desc)])
  @@map("plan_scenario_logs")
}

model PlanBundleLog {
  id            String    @id @default(uuid(7))
  planId        String    @map("plan_id")
  moduleKey     String    @default("EXEC") @map("module_key")
  scenario      String
  year          Int
  tabKey        String    @map("tab_key")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @map("created_by")
  schemaVersion String    @default("1") @map("schema_version")
  deletedAt     DateTime? @map("deleted_at")
  rawJson       Json?     @map("raw_json")
  note          String?

  @@index([planId])
  @@index([year, scenario, tabKey])
  @@index([createdAt(sort: Desc)])
  @@map("plan_bundle_logs")
}

model ExecPlanLatest {
  id             String   @id @default(uuid(7))
  year           Int
  scenarioKey    String   @map("scenario_key")
  tabKey         String   @map("tab_key")
  latestPlanId   String?  @map("latest_plan_id")
  latestBundleId String?  @map("latest_bundle_id")
  updatedAt      DateTime @default(now()) @map("updated_at")
  updatedBy      String?  @map("updated_by")
  schemaVersion  String   @default("1") @map("schema_version")
  rawJson        Json?    @map("raw_json")
  note           String?

  @@unique([year, scenarioKey, tabKey])
  @@map("exec_plan_latest")
}

model ExecKpiLatest {
  id           String   @id @default(uuid(7))
  year         Int
  scenarioKey  String
  tabKey       String
  kpiKey       String
  value        Float    @default(0)
  unit         String?
  sourcePlanId String?
  calcVersion  String?
  updatedAt    DateTime @default(now())
  updatedBy    String?
  note         String?

  @@unique([year, scenarioKey, tabKey, kpiKey])
  @@map("exec_kpi_latest")
}

model ExecKpiLog {
  id           String   @id @default(uuid(7))
  snapshotId   String
  year         Int
  scenarioKey  String
  tabKey       String
  kpiKey       String
  value        Float    @default(0)
  unit         String?
  sourcePlanId String?
  calcVersion  String?
  createdAt    DateTime @default(now())
  createdBy    String?
  rawJson      String?
  note         String?

  @@index([snapshotId])
  @@index([year, scenarioKey])
  @@index([createdAt(sort: Desc)])
  @@map("exec_kpi_logs")
}

// ══════════════════════════════════════════════════════════════════
// SALES PLANNING (port from GAS Service_SalesPlanning.js)
// ══════════════════════════════════════════════════════════════════
model SalePlanLatest {
  id          String   @id @default(uuid(7))
  year        Int
  scenarioKey String
  planId      String
  updatedAt   DateTime @default(now())
  updatedBy   String?
  version     String?
  rawJson     String?
  note        String?

  @@unique([year, scenarioKey])
  @@map("sale_plan_latest")
}

model SalePlanHeader {
  id            String   @id @default(uuid(7))
  planId        String
  year          Int
  scenarioKey   String
  ownerEmail    String?
  status        String   @default("DRAFT")
  targetGMV     Decimal  @default(0) @db.Decimal(18, 4)
  avgDealValue  Decimal  @default(0) @db.Decimal(18, 4)
  headcount     Int      @default(0)
  marketingRate Float    @default(0)
  rateDeal      Float    @default(0)
  rateBooking   Float    @default(0)
  rateMeeting   Float    @default(0)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([planId])
  @@index([year, scenarioKey])
  @@map("sale_plan_headers")
}

model SalePlanMonth {
  id          String   @id @default(uuid(7))
  planId      String
  year        Int
  scenarioKey String
  month       Int
  weight      Float    @default(0)
  gmv         Decimal  @default(0) @db.Decimal(18, 4)
  deals       Int      @default(0)
  bookings    Int      @default(0)
  meetings    Int      @default(0)
  leadsSale   Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())

  @@unique([planId, year, scenarioKey, month])
  @@index([planId])
  @@map("sale_plan_months")
}

model SalePlanTeam {
  id          String   @id @default(uuid(7))
  planId      String
  year        Int
  scenarioKey String
  teamId      String?
  name        String
  leaderId    String?
  leaderName  String?
  status      String   @default("active")
  activeFrom  Int      @default(1)
  activeTo    Int      @default(12)
  sortOrder   Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey])
  @@map("sale_plan_teams")
}

model SalePlanStaff {
  id            String   @id @default(uuid(7))
  planId        String
  year          Int
  scenarioKey   String
  staffId       String?
  hoTen         String
  role          String   @default("Sales")
  team          String?
  status        String   @default("active")
  activeFrom    Int      @default(1)
  activeTo      Int      @default(12)
  leadsCapacity Float    @default(0)
  rateMeeting   Float    @default(0)
  rateBooking   Float    @default(0)
  rateDeal      Float    @default(0)
  note          String?
  createdAt     DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey])
  @@map("sale_plan_staff")
}

// ══════════════════════════════════════════════════════════════════
// MARKETING PLANNING (port from GAS Service_MarketingPlanning.js)
// ══════════════════════════════════════════════════════════════════
model MktPlanHeader {
  id             String   @id @default(uuid(7))
  planId         String   @unique
  year           Int
  scenarioKey    String
  ownerEmail     String?
  status         String   @default("DRAFT")
  totalBudgetVnd Decimal  @default(0) @db.Decimal(18, 4)
  currency       String   @default("VND")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([year, scenarioKey])
  @@map("mkt_plan_headers")
}

model MktPlanChannelBudget {
  id              String   @id @default(uuid(7))
  planId          String
  year            Int
  scenarioKey     String
  channelKey      String
  channelLabel    String?
  budgetVnd       Decimal  @default(0) @db.Decimal(18, 4)
  pct             Float    @default(0)
  kpiLeadTarget   Float?
  kpiCplTargetVnd Decimal? @db.Decimal(18, 4)
  note            String?
  updatedAt       DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey, channelKey])
  @@map("mkt_plan_channel_budgets")
}

model MktPlanKpiTarget {
  id          String   @id @default(uuid(7))
  planId      String
  year        Int
  scenarioKey String
  kpiKey      String
  kpiLabel    String?
  targetValue Float    @default(0)
  unit        String?
  note        String?
  updatedAt   DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey])
  @@map("mkt_plan_kpi_targets")
}

model MktPlanAssumption {
  id          String   @id @default(uuid(7))
  planId      String
  year        Int
  scenarioKey String
  key         String
  label       String?
  value       Float    @default(0)
  unit        String?
  note        String?
  updatedAt   DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey])
  @@map("mkt_plan_assumptions")
}

// ══════════════════════════════════════════════════════════════════
// MARKETING MODULE — Operational (Campaigns, Leads, Content, Channels)
// ══════════════════════════════════════════════════════════════════

model MktCampaign {
  id          String   @id @default(uuid(7))
  name        String
  channel     String   @default("FACEBOOK") // FACEBOOK, GOOGLE, ZALO, TIKTOK, EMAIL, SMS, OFFLINE
  budget      Decimal  @default(0) @db.Decimal(18, 2)
  spend       Decimal  @default(0) @db.Decimal(18, 2)
  leads       Int      @default(0)
  conversions Int      @default(0)
  status      String   @default("DRAFT") // DRAFT, RUNNING, PAUSED, COMPLETED, CANCELLED
  startDate   DateTime?
  endDate     DateTime?
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mktLeads MktLead[]

  @@index([status])
  @@index([channel])
  @@index([startDate, endDate])
  @@map("mkt_campaigns")
}

model MktLead {
  id          String       @id @default(uuid(7))
  name        String
  email       String?
  phone       String?
  source      String       @default("WEBSITE") // WEBSITE, FACEBOOK, GOOGLE, ZALO, REFERRAL, EVENT, OTHER
  status      String       @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL, WON, LOST
  assignedTo  String?
  assignedName String?
  campaignId  String?
  campaign    MktCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  note        String?
  score       Int          @default(0) // Lead score 0-100
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([source])
  @@index([campaignId])
  @@index([assignedTo])
  @@index([createdAt(sort: Desc)])
  @@map("mkt_leads")
}

model MktContent {
  id            String   @id @default(uuid(7))
  title         String
  contentType   String   @default("POST") // POST, VIDEO, REEL, STORY, BLOG, EMAIL
  channel       String   @default("FACEBOOK") // FACEBOOK, INSTAGRAM, TIKTOK, YOUTUBE, BLOG, EMAIL
  scheduledDate DateTime?
  publishedDate DateTime?
  status        String   @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, ARCHIVED
  author        String?
  description   String?
  engagement    Int      @default(0) // Total interactions
  reach         Int      @default(0) // Total reach
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([scheduledDate])
  @@map("mkt_contents")
}

model MktChannelPerformance {
  id         String   @id @default(uuid(7))
  channelKey String // FACEBOOK, GOOGLE, ZALO, TIKTOK, etc.
  period     String // "2026-03" format
  year       Int
  month      Int
  leads      Int      @default(0)
  spend      Decimal  @default(0) @db.Decimal(18, 2)
  roas       Float    @default(0)
  cpl        Decimal  @default(0) @db.Decimal(18, 2) // Cost per lead
  conversions Int     @default(0)
  revenue    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([channelKey, period])
  @@index([year, month])
  @@map("mkt_channel_performances")
}

// ══════════════════════════════════════════════════════════════════
// SHARED: Audit & Snapshot
// ══════════════════════════════════════════════════════════════════
model FactPlanSnapshotLog {
  id          String   @id @default(uuid(7))
  snapshotId  String
  planId      String
  year        Int
  scenarioKey String
  ownerEmail  String?
  json        String?
  createdAt   DateTime @default(now())

  @@index([planId])
  @@index([year, scenarioKey])
  @@index([createdAt(sort: Desc)])
  @@map("fact_plan_snapshot_logs")
}

model AuditLog {
  id         String   @id @default(uuid(7))
  auditId    String
  action     String
  entity     String
  entityId   String?
  actorEmail String?
  ipAddress  String? // Track access source
  oldValue   Json? // Previous state (JSONB)
  newValue   Json? // New state (JSONB)
  meta       String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorEmail])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Dimension Tables
// ══════════════════════════════════════════════════════════════════

model DimProject {
  id          String    @id @default(uuid(7))
  projectCode String    @unique
  name        String
  developer   String?
  location    String?
  type        String? // "Chung cư", "Biệt thự", "Shophouse"
  feeRate     Float     @default(0) // Phí MG mặc định (%)
  avgPrice    Decimal   @default(0) @db.Decimal(18, 4) // Giá bán TB (Tỷ)
  totalUnits  Int       @default(0)
  soldUnits   Int       @default(0)
  status      String    @default("ACTIVE") // ACTIVE, PAUSED, CLOSED
  startDate   DateTime?
  endDate     DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  deals               FactDeal[]
  legalDocs           LegalProjectDoc[]
  products            PropertyProduct[]
  financeTransactions FinanceTransaction[]
  debtRecords         DebtRecord[]
  bookings            SalesBooking[]
  deposits            SalesDeposit[]
  appointments        Appointment[]

  @@index([status])
  @@index([deletedAt])
  @@map("dim_projects")
}

model SalesTeam {
  id           String        @id @default(uuid(7))
  code         String        @unique
  name         String
  leaderId     String?
  leaderName   String?
  departmentId String?
  department   HrDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  region       String?
  status       String        @default("ACTIVE")
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  members       SalesStaff[]
  deals         FactDeal[]
  dailyStats    FactSalesDaily[]
  targets       SalesTargetMonthly[]
  activities    SalesActivity[]
  bookings      SalesBooking[]
  deposits      SalesDeposit[]
  commissions   CommissionRecord[]
  users         User[]
  transfersFrom SalesTeamTransfer[]  @relation("TransferFrom")
  transfersTo   SalesTeamTransfer[]  @relation("TransferTo")

  @@index([deletedAt])
  @@map("sales_teams")
}

model SalesStaff {
  id             String      @id @default(uuid(7))
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  hrEmployeeId   String?     @unique
  hrEmployee     HrEmployee? @relation(fields: [hrEmployeeId], references: [id])
  employeeCode   String?     @unique
  fullName       String
  phone          String?
  email          String?
  teamId         String?
  team           SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  role           String      @default("sales") // sales, senior_sales, team_lead
  status         String      @default("ACTIVE")
  joinDate       DateTime?
  leaveDate      DateTime?
  leadsCapacity  Float       @default(30)
  personalTarget Decimal     @default(0) @db.Decimal(18, 4) // Target GMV tháng (Tỷ)
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  deals               FactDeal[]
  dailyStats          FactSalesDaily[]
  activities          SalesActivity[]
  targets             SalesTargetMonthly[]
  bookings            SalesBooking[]
  deposits            SalesDeposit[]
  appointments        Appointment[]
  commissions         CommissionRecord[]
  financeTransactions FinanceTransaction[]
  debtRecords         DebtRecord[]
  teamTransfers       SalesTeamTransfer[]

  @@index([deletedAt])
  @@map("sales_staff")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Fact Tables
// ══════════════════════════════════════════════════════════════════

model FactDeal {
  id            String      @id @default(uuid(7))
  dealCode      String?     @unique
  bizflyCrmId   String?
  projectId     String?
  project       DimProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName   String? // denorm: snapshot tại thời điểm tạo deal
  staffId       String?
  staff         SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  staffName     String? // denorm: snapshot
  teamId        String?
  team          SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamName      String? // denorm: snapshot
  customerName  String?
  customerPhone String?
  productCode   String?
  productType   String?
  dealValue     Decimal     @default(0) @db.Decimal(18, 4) // Tỷ
  feeRate       Float       @default(0) // %
  commission    Decimal     @default(0) @db.Decimal(18, 4) // Tỷ
  stage         DealStage   @default(LEAD)
  dealDate      DateTime?
  bookingDate   DateTime?
  contractDate  DateTime?
  source        LeadSource?
  note          String?
  year          Int
  month         Int
  status        String      @default("ACTIVE")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime? // Soft delete

  legalDocs           LegalTransactionDoc[]
  commissions         CommissionRecord[]
  financeTransactions FinanceTransaction[]
  debtRecords         DebtRecord[]

  @@index([year, month])
  @@index([projectId])
  @@index([teamId])
  @@index([staffId])
  @@index([stage])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("fact_deals")
}

model SalesBooking {
  id               String      @id @default(uuid(7))
  projectId        String?
  project          DimProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName      String
  customerName     String
  customerPhone    String
  bookingAmount    Decimal     @default(0) @db.Decimal(18, 4)
  bookingCount     Int         @default(1)
  staffId          String?
  staff            SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  staffName        String?
  teamId           String?
  team             SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamName         String?
  status           String      @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELED
  bookingDate      DateTime    @default(now())
  note             String?
  createdByUserId  String?
  createdByName    String?
  reviewedByUserId String?
  reviewedByName   String?
  reviewedAt       DateTime?
  year             Int
  month            Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  @@index([year, month])
  @@index([projectId])
  @@index([staffId])
  @@index([teamId])
  @@index([status])
  @@index([bookingDate(sort: Desc)])
  @@index([deletedAt])
  @@map("sales_bookings")
}

model SalesDeposit {
  id               String      @id @default(uuid(7))
  projectId        String?
  project          DimProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName      String
  unitCode         String
  customerName     String
  customerPhone    String
  depositAmount    Decimal     @default(0) @db.Decimal(18, 4)
  staffId          String?
  staff            SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  staffName        String?
  teamId           String?
  team             SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamName         String?
  paymentMethod    String?
  receiptNo        String?
  notes            String?
  status           String      @default("PENDING") // PENDING, CONFIRMED, CANCELLED, REFUNDED
  depositDate      DateTime    @default(now())
  createdByUserId  String?
  createdByName    String?
  reviewedByUserId String?
  reviewedByName   String?
  reviewedAt       DateTime?
  year             Int
  month            Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  @@index([year, month])
  @@index([projectId])
  @@index([staffId])
  @@index([teamId])
  @@index([status])
  @@index([depositDate(sort: Desc)])
  @@index([deletedAt])
  @@map("sales_deposits")
}

model FactSalesDaily {
  id             String      @id @default(uuid(7))
  date           DateTime
  year           Int
  month          Int
  week           Int
  teamId         String?
  team           SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  staffId        String?
  staff          SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  newLeads       Int         @default(0)
  meetings       Int         @default(0)
  bookings       Int         @default(0)
  deposits       Int         @default(0)
  contracts      Int         @default(0)
  completedDeals Int         @default(0)
  cancelledDeals Int         @default(0)
  gmv            Decimal     @default(0) @db.Decimal(18, 4)
  revenue        Decimal     @default(0) @db.Decimal(18, 4)
  source         String      @default("MANUAL") // MANUAL, BIZFLY_SYNC
  syncedAt       DateTime?
  createdAt      DateTime    @default(now())

  @@unique([date, teamId, staffId])
  @@map("fact_sales_daily")
}

model FactPipelineSnapshot {
  id                 String   @id @default(uuid(7))
  snapshotDate       DateTime
  year               Int
  month              Int
  teamId             String?
  leadCount          Int      @default(0)
  contactedCount     Int      @default(0)
  meetingCount       Int      @default(0)
  bookingCount       Int      @default(0)
  depositCount       Int      @default(0)
  contractCount      Int      @default(0)
  completedCount     Int      @default(0)
  totalPipelineValue Decimal  @default(0) @db.Decimal(18, 4)
  source             String   @default("MANUAL")
  createdAt          DateTime @default(now())

  @@unique([snapshotDate, teamId])
  @@map("fact_pipeline_snapshots")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Commission & Target
// ══════════════════════════════════════════════════════════════════

model CommissionRecord {
  id               String     @id @default(uuid(7))
  dealId           String
  deal             FactDeal   @relation(fields: [dealId], references: [id])
  staffId          String
  staff            SalesStaff @relation(fields: [staffId], references: [id])
  staffName        String?
  teamId           String?
  team             SalesTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  role             String // SALES, MANAGER, DIRECTOR
  dealValue        Decimal    @default(0) @db.Decimal(18, 4)
  commissionRate   Float      @default(0)
  commissionAmount Decimal    @default(0) @db.Decimal(18, 4)
  status           String     @default("PENDING") // PENDING, APPROVED, PAID
  period           String? // "2026-03"
  approvedBy       String?
  approvedAt       DateTime?
  paidAt           DateTime?
  year             Int
  month            Int
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([dealId])
  @@index([staffId])
  @@index([teamId])
  @@index([year, month])
  @@index([status])
  @@map("commission_records")
}

model SalesTargetMonthly {
  id             String      @id @default(uuid(7))
  year           Int
  month          Int
  teamId         String?
  team           SalesTeam?  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  staffId        String?
  staff          SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  targetGMV      Decimal     @default(0) @db.Decimal(18, 4)
  targetDeals    Int         @default(0)
  targetLeads    Int         @default(0)
  targetMeetings Int         @default(0)
  targetBookings Int         @default(0)
  scenarioKey    String      @default("base")
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([year, month, teamId, staffId, scenarioKey])
  @@map("sales_target_monthly")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Bizfly CRM Sync
// ══════════════════════════════════════════════════════════════════

model BizflySyncLog {
  id            String    @id @default(uuid(7))
  syncType      String // LEADS, DEALS, PIPELINE
  syncDirection String    @default("PULL")
  status        String    @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED
  recordsTotal  Int       @default(0)
  recordsSynced Int       @default(0)
  recordsFailed Int       @default(0)
  errorMessage  String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  initiatedBy   String?
  metadata      String?

  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("bizfly_sync_logs")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — CRM (Customer / Lead)
// ══════════════════════════════════════════════════════════════════

model Customer {
  id              String      @id @default(uuid(7))
  fullName        String
  phone           String?
  email           String?
  source          LeadSource?
  projectInterest String?
  budget          String?
  status          String      @default("NEW") // NEW, CONTACTED, INTERESTED, MEETING, NEGOTIATION, WON, LOST
  assignedTo      String? // staffId
  assignedName    String?
  isVip           Boolean     @default(false)
  lastContactAt   DateTime?
  // Expanded CRM fields
  companyName     String? // Tên công ty (B2B)
  birthday        DateTime? // Marketing automation
  address         String? // Địa chỉ liên hệ
  tags            String? // JSON array of tags
  utmSource       String? // UTM tracking
  utmMedium       String?
  utmCampaign     String?
  note            String?
  year            Int
  month           Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime? // Soft delete — null = còn active

  legalDocs           LegalTransactionDoc[]
  appointments        Appointment[]
  financeTransactions FinanceTransaction[]
  debtRecords         DebtRecord[]

  @@index([year, month])
  @@index([status])
  @@index([assignedTo])
  @@index([source])
  @@index([createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("customers")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Daily Activity Log
// ══════════════════════════════════════════════════════════════════

model SalesActivity {
  id           String     @id @default(uuid(7))
  date         DateTime   @default(now())
  staffId      String
  staff        SalesStaff @relation(fields: [staffId], references: [id])
  staffName    String?
  teamId       String?
  team         SalesTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamName     String?
  postsCount   Int        @default(0)
  callsCount   Int        @default(0)
  newLeads     Int        @default(0)
  meetingsMade Int        @default(0)
  note         String?
  year         Int
  month        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([year, month])
  @@index([staffId])
  @@index([teamId])
  @@index([date(sort: Desc)])
  @@map("sales_activities")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Appointments / Calendar
// ══════════════════════════════════════════════════════════════════

model Appointment {
  id            String            @id @default(uuid(7))
  staffId       String
  staff         SalesStaff        @relation(fields: [staffId], references: [id])
  staffName     String?
  customerId    String?
  customer      Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String?
  customerPhone String?
  projectId     String?
  project       DimProject?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectName   String?
  type          AppointmentType   @default(MEETING)
  scheduledAt   DateTime
  duration      Int               @default(60) // minutes
  location      String?
  status        AppointmentStatus @default(SCHEDULED)
  outcome       String?
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([staffId])
  @@index([customerId])
  @@index([projectId])
  @@index([scheduledAt(sort: Desc)])
  @@index([status])
  @@map("appointments")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Property Products (Inventory per-unit)
// ══════════════════════════════════════════════════════════════════

model PropertyProduct {
  id            String             @id @default(uuid(7))
  projectId     String
  project       DimProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectName   String?
  code          String             @unique
  block         String?
  floor         Int                @default(0)
  area          Float              @default(0)
  price         Decimal            @default(0) @db.Decimal(18, 4) // Tỷ VND
  direction     String?
  bedrooms      Int                @default(0)
  status        PropertyUnitStatus @default(AVAILABLE)
  bookedBy      String?
  lockedUntil   DateTime?
  customerPhone String?
  note          String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  statusLogs ProductStatusLog[]

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("property_products")
}

model ProductStatusLog {
  id        String          @id @default(uuid(7))
  productId String
  product   PropertyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldStatus String
  newStatus String
  changedBy String?
  reason    String?
  createdAt DateTime        @default(now())

  @@index([productId])
  @@index([createdAt(sort: Desc)])
  @@map("product_status_logs")
}

// ══════════════════════════════════════════════════════════════════
// SALES MODULE — Team Transfer History
// ══════════════════════════════════════════════════════════════════

model SalesTeamTransfer {
  id           String     @id @default(uuid(7))
  staffId      String
  staff        SalesStaff @relation(fields: [staffId], references: [id])
  fromTeamId   String?
  fromTeam     SalesTeam? @relation("TransferFrom", fields: [fromTeamId], references: [id], onDelete: SetNull)
  toTeamId     String
  toTeam       SalesTeam  @relation("TransferTo", fields: [toTeamId], references: [id])
  transferDate DateTime   @default(now())
  reason       String?
  approvedBy   String?
  createdAt    DateTime   @default(now())

  @@index([staffId])
  @@index([transferDate(sort: Desc)])
  @@map("sales_team_transfers")
}

// ══════════════════════════════════════════════════════════════════
// HR MODULE
// ══════════════════════════════════════════════════════════════════

// 1. Tổ chức nhân sự
model HrDepartment {
  id          String      @id @default(uuid(7))
  code        String      @unique
  name        String
  description String?
  managerId   String?
  manager     HrEmployee? @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employees  HrEmployee[] @relation("EmployeeDepartment")
  salesTeams SalesTeam[]

  @@map("hr_departments")
}

model HrPosition {
  id          String   @id @default(uuid(7))
  code        String   @unique
  name        String
  level       String? // Staff, Leader, Manager, Director
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees HrEmployee[]

  @@map("hr_positions")
}

// 2. Hồ sơ nhân viên trung tâm
model HrEmployee {
  id             String        @id @default(uuid(7))
  userId         String?       @unique // Link to User account if they have app access
  employeeCode   String        @unique
  fullName       String
  gender         String? // MALE, FEMALE, OTHER
  dateOfBirth    DateTime?
  phone          String?
  email          String?
  personalEmail  String?
  address        String?
  identityNumber String?       @unique // CMND/CCCD
  bankName       String?
  bankAccount    String?
  departmentId   String?
  department     HrDepartment? @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  positionId     String?
  position       HrPosition?   @relation(fields: [positionId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        HrEmployee?   @relation("EmployeeToManager", fields: [managerId], references: [id])
  subordinates   HrEmployee[]  @relation("EmployeeToManager")
  joinDate       DateTime
  leaveDate      DateTime?
  status         String        @default("PROBATION") // PROBATION, ACTIVE, ON_LEAVE, TERMINATED
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  contracts          HrContract[]
  attendances        HrAttendance[]
  leaveRequests      HrLeaveRequest[]      @relation("LeaveEmployee")
  approvedLeaves     HrLeaveRequest[]      @relation("LeaveApprover")
  salaryRecords      HrSalaryRecord[]
  reviews            HrPerformanceReview[] @relation("ReviewEmployee")
  reviewsGiven       HrPerformanceReview[] @relation("ReviewReviewer")
  salesProfile       SalesStaff?
  managedDepartments HrDepartment[]        @relation("DepartmentManager")

  @@index([departmentId])
  @@index([positionId])
  @@index([status])
  @@map("hr_employees")
}

// 3. Hợp đồng lao động
model HrContract {
  id           String       @id @default(uuid(7))
  employeeId   String
  employee     HrEmployee   @relation(fields: [employeeId], references: [id])
  contractCode String       @unique
  contractType ContractType
  startDate    DateTime
  endDate      DateTime?
  baseSalary   Decimal      @default(0) @db.Decimal(18, 2) // Lương cơ bản/Vùng
  grossSalary  Decimal      @default(0) @db.Decimal(18, 2) // Lương thoả thuận
  status       String       @default("ACTIVE") // DRAFT, ACTIVE, EXPIRED, TERMINATED
  documentUrl  String? // Link to PDF
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([endDate])
  @@map("hr_contracts")
}

// 4. Chấm công & Nghỉ phép
model HrAttendance {
  id           String           @id @default(uuid(7))
  employeeId   String
  employee     HrEmployee       @relation(fields: [employeeId], references: [id])
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  workingHours Float            @default(0)
  status       AttendanceStatus @default(PRESENT)
  locationInfo String? // GPS or IP tracking if needed
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([employeeId, date])
  @@map("hr_attendances")
}

model HrLeaveRequest {
  id         String      @id @default(uuid(7))
  employeeId String
  employee   HrEmployee  @relation("LeaveEmployee", fields: [employeeId], references: [id])
  leaveType  LeaveType
  startDate  DateTime
  endDate    DateTime
  totalDays  Float
  reason     String
  status     String      @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  approverId String?
  approver   HrEmployee? @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt DateTime?
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("hr_leave_requests")
}

// 5. Tiền lương (Bảng lương chuẩn hoá)
model HrSalaryRecord {
  id               String     @id @default(uuid(7))
  employeeId       String
  employee         HrEmployee @relation(fields: [employeeId], references: [id])
  period           String // e.g., "2026-03"
  year             Int
  month            Int
  standardWorkDays Float      @default(0) // Ngày công chuẩn
  actualWorkDays   Float      @default(0) // Ngày đi làm
  paidLeaveDays    Float      @default(0) // Ngày nghỉ có phép
  baseSalaryValue  Decimal    @default(0) @db.Decimal(18, 2)
  totalAllowance   Decimal    @default(0) @db.Decimal(18, 2)
  totalDeduction   Decimal    @default(0) @db.Decimal(18, 2) // Phạt, trễ giờ...
  taxBhiT          Decimal    @default(0) @db.Decimal(18, 2) // Thuế, BHXH, BHYT trích trừ
  commission       Decimal    @default(0) @db.Decimal(18, 2) // Bonus/Hoa hồng tự động map từ module Sales sang
  netPay           Decimal    @default(0) @db.Decimal(18, 2) // Thực lãnh
  status           String     @default("DRAFT") // DRAFT, REVIEWING, APPROVED, PAID
  paidAt           DateTime?
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  salaryItems HrSalaryItem[]

  @@unique([employeeId, period])
  @@index([year, month])
  @@index([status])
  @@map("hr_salary_records")
}

// 5.1 Chi tiết phụ cấp / khoản trừ cho bảng lương
model HrSalaryItem {
  id        String         @id @default(uuid(7))
  salaryId  String
  salary    HrSalaryRecord @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  type      String // ALLOWANCE, DEDUCTION, BONUS
  itemCode  String // MEAL, TRANSPORT, PHONE, LATE_PENALTY...
  itemName  String
  amount    Decimal        @default(0) @db.Decimal(18, 2)
  note      String?
  createdAt DateTime       @default(now())

  @@index([salaryId])
  @@map("hr_salary_items")
}

// 6. Đánh giá hiệu suất
model HrPerformanceReview {
  id           String     @id @default(uuid(7))
  employeeId   String
  employee     HrEmployee @relation("ReviewEmployee", fields: [employeeId], references: [id])
  reviewerId   String
  reviewer     HrEmployee @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  period       String // e.g., "Q1-2026"
  overallScore Float      @default(0) // scale 1-5 or 1-100
  kpiSnapshot  String? // JSON of KPIs attained
  strengths    String?
  weaknesses   String?
  goals        String?
  status       String     @default("DRAFT") // DRAFT, SUBMITTED, ACKNOWLEDGED
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([employeeId])
  @@index([reviewerId])
  @@index([period])
  @@map("hr_performance_reviews")
}

model HrJobPosting {
  id          String    @id @default(uuid(7))
  title       String
  department  String?
  type        String    @default("Full-time")
  location    String?
  description String?
  candidates  Int       @default(0)
  status      String    @default("OPEN") // OPEN, URGENT, CLOSED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applicants  HrCandidate[]

  @@index([status])
  @@map("hr_job_postings")
}

model HrCandidate {
  id        String       @id @default(uuid(7))
  jobId     String?
  job       HrJobPosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  name      String
  email     String?
  phone     String?
  source    String?  // LinkedIn, Facebook, TopCV, Referral
  stage     String   @default("NEW") // NEW, INTERVIEW, OFFERRED, REJECTED, HIRED
  rating    String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([stage])
  @@map("hr_candidates")
}

model HrCourse {
  id          String    @id @default(uuid(7))
  title       String
  category    String?
  duration    String?
  description String?
  enrolled    Int       @default(0)
  completed   Int       @default(0)
  status      String    @default("OPEN") // OPEN, URGENT, CLOSED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  trainees    HrTrainee[]

  @@index([status])
  @@map("hr_courses")
}

model HrTrainee {
  id        String    @id @default(uuid(7))
  courseId   String?
  course    HrCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  employeeCode String?
  name      String
  progress  Int       @default(0) // 0-100
  score     String?
  status    String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([courseId])
  @@index([status])
  @@map("hr_trainees")
}

// ══════════════════════════════════════════════════════════════════
// LEGAL & DOCUMENT MODULE
// ══════════════════════════════════════════════════════════════════

model LegalProjectDoc {
  id          String     @id @default(uuid(7))
  projectId   String
  project     DimProject @relation(fields: [projectId], references: [id])
  name        String // e.g., "Quyết định 1/500", "Giấy phép xây dựng"
  docType     String     @default("GENERAL") // GENERAL, LICENSE, DECISION, CERTIFICATE
  fileUrl     String?
  issuedDate  DateTime?
  expiredDate DateTime?
  status      String     @default("VALID") // VALID, EXPIRED, REVOKED, PENDING
  note        String?
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([expiredDate])
  @@map("legal_project_docs")
}

model ProjectPolicy {
  id          String     @id @default(uuid(7))
  projectId   String?
  name        String
  startDate   DateTime?
  endDate     DateTime?
  status      String     @default("DRAFT") // ACTIVE, DRAFT, EXPIRED
  rules       String?    // JSON array of rule strings
  color       String     @default("#10b981")
  description String?
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([projectId])
  @@map("project_policies")
}

model ProjectAssignment {
  id         String     @id @default(uuid(7))
  projectId  String?
  userId     String?
  name       String     // User display name
  email      String?
  role       String     @default("Sales Rep") // Project Manager, Sales Director, Sales Manager, etc.
  status     String     @default("ACTIVE") // ACTIVE, INACTIVE
  assignedAt DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("project_assignments")
}


model LegalTransactionDoc {
  id         String    @id @default(uuid(7))
  dealId     String
  deal       FactDeal  @relation(fields: [dealId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name       String // e.g., "Hợp đồng cọc mã 001", "CMND Nguyễn Văn A"
  docType    String    @default("CONTRACT") // CONTRACT, KYC, RECEIPT, ANNEX
  fileUrl    String?
  signedDate DateTime?
  status     String    @default("DRAFT") // DRAFT, PENDING_SIGN, SIGNED, CANCELLED
  note       String?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([dealId])
  @@index([customerId])
  @@index([status])
  @@map("legal_transaction_docs")
}

model LegalTemplate {
  id          String   @id @default(uuid(7))
  name        String
  description String?
  docType     String   @default("CONTRACT") // CONTRACT, FORM, RECEIPT
  fileUrl     String
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("legal_templates")
}

// ══════════════════════════════════════════════════════════════════
// FINANCE & ACCOUNTING MODULE
// ══════════════════════════════════════════════════════════════════

model FinanceAccount {
  id             String   @id @default(uuid(7))
  accountCode    String   @unique
  accountName    String
  accountType    String   @default("BANK") // CASH, BANK, EPAY
  bankName       String?
  bankNumber     String?
  initialBalance Decimal  @default(0) @db.Decimal(18, 2)
  currentBalance Decimal  @default(0) @db.Decimal(18, 2)
  currency       String   @default("VND")
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions FinanceTransaction[]

  @@map("finance_accounts")
}

model FinanceCategory {
  id           String   @id @default(uuid(7))
  categoryCode String   @unique
  categoryName String
  type         String // INCOME, EXPENSE
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions FinanceTransaction[]
  budgets      FinanceBudget[]

  @@map("finance_categories")
}

model FinanceTransaction {
  id              String  @id @default(uuid(7))
  transactionCode String  @unique // PT..., PC...
  type            String // INCOME (Thu), EXPENSE (Chi)
  amount          Decimal @default(0) @db.Decimal(18, 2)
  currency        String  @default("VND")

  accountId String
  account   FinanceAccount @relation(fields: [accountId], references: [id])

  categoryId String
  category   FinanceCategory @relation(fields: [categoryId], references: [id])

  // Liên kết (Relations) với các module khác
  dealId     String?
  deal       FactDeal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  projectId  String?
  project    DimProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staffId    String?
  staff      SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  // Thông tin đối tượng Thanh toán / Thu tiền
  payerName    String?
  receiverName String?

  paymentMethod String   @default("BANK_TRANSFER") // CASH, BANK_TRANSFER
  paymentDate   DateTime

  status String @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED, CANCELLED

  approvedBy String?
  approvedAt DateTime?

  documentUrl String? // Link ảnh uỷ nhiệm chi, phiếu thu...
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  debtRecords DebtRecord[]

  @@index([accountId])
  @@index([categoryId])
  @@index([dealId])
  @@index([projectId])
  @@index([customerId])
  @@index([staffId])
  @@index([paymentDate(sort: Desc)])
  @@index([status])
  @@index([type])
  @@map("finance_transactions")
}

model DebtRecord {
  id       String   @id @default(uuid(7))
  debtCode String   @unique
  debtType DebtType

  // Đối tượng Công nợ
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId  String?
  project    DimProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  staffId    String?
  staff      SalesStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  dealId     String?
  deal       FactDeal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  totalAmount     Decimal @default(0) @db.Decimal(18, 2)
  paidAmount      Decimal @default(0) @db.Decimal(18, 2)
  remainingAmount Decimal @default(0) @db.Decimal(18, 2)

  dueDate DateTime?
  status  String    @default("UNPAID") // UNPAID, PARTIAL, PAID, OVERDUE, CANCELLED

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Link với các lần thanh toán (Phiếu thu / Phiếu chi)
  transactionId String?
  transaction   FinanceTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
  @@index([staffId])
  @@index([dealId])
  @@index([transactionId])
  @@index([debtType])
  @@index([status])
  @@index([dueDate])
  @@map("debt_records")
}

// ══════════════════════════════════════════════════════════════════
// FINANCE — Budget Tracking
// ══════════════════════════════════════════════════════════════════

model FinanceBudget {
  id           String          @id @default(uuid(7))
  year         Int
  month        Int
  categoryId   String
  category     FinanceCategory @relation(fields: [categoryId], references: [id])
  budgetAmount Decimal         @default(0) @db.Decimal(18, 2)
  actualAmount Decimal         @default(0) @db.Decimal(18, 2)
  variance     Decimal         @default(0) @db.Decimal(18, 2)
  note         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([year, month, categoryId])
  @@map("finance_budgets")
}

// ══════════════════════════════════════════════════════════════════
// NOTIFICATION SYSTEM
// ══════════════════════════════════════════════════════════════════

model Notification {
  id         String    @id @default(uuid(7))
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String
  type       String    @default("INFO") // INFO, WARNING, APPROVAL, DEADLINE
  entityType String? // "DEAL", "LEAVE_REQUEST", "TRANSACTION"
  entityId   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("notifications")
}

// ══════════════════════════════════════════════════════════════════
// FILE ATTACHMENT MANAGEMENT
// ══════════════════════════════════════════════════════════════════

model FileAttachment {
  id         String   @id @default(uuid(7))
  fileName   String
  fileUrl    String
  fileSize   Int? // bytes
  mimeType   String?
  entityType String // "LEGAL_DOC", "CONTRACT", "TRANSACTION", "HR_CONTRACT"
  entityId   String
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("file_attachments")
}

