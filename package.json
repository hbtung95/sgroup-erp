{
  "name": "sgroup-erp-full",
  "version": "1.0.0",
  "packageManager": "npm@11.11.0",
  "description": "Monorepo chứa toàn bộ hệ thống ERP cho SGROUP.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "turbo run build",
    "dev:web": "npm.cmd run dev --workspace @sgroup/web-host",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1",
    "lint": "turbo run lint",
    "typecheck": "npx.cmd tsc -b core/web-host",
    "test": "echo \"No automated tests configured yet\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vctplatform/sgroup-erp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vctplatform/sgroup-erp/issues"
  },
  "homepage": "https://github.com/vctplatform/sgroup-erp#readme",
  "workspaces": [
    "core/*",
    "modules/*/web",
    "modules/*/app",
    "packages/*"
  ],
  "devDependencies": {
    "@next/swc-win32-x64-msvc": "^16.2.3",
    "turbo": "^2.9.5"
  }
}
