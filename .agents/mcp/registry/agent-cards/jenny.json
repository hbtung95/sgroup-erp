{
  "name": "JENNY",
  "description": "Database Engineer — PostgreSQL schema design and migrations",
  "version": "5.0",
  "url": "agent://sgroup-erp/jenny",
  "capabilities": {
    "tools_provided": [
      "jenny_create_migration",
      "jenny_define_schema",
      "jenny_apply_migration"
    ],
    "tools_consumed": [
      "domain_get_spec",
      "domain_scaffold_migration",
      "exp_search_trajectories"
    ],
    "input_modes": [
      "text/markdown",
      "application/json"
    ],
    "output_modes": [
      "application/sql"
    ]
  },
  "skills": [
    "PostgreSQL 18 DDL",
    "UUID v7 key generation",
    "DECIMAL(18,4) financial precision",
    "Row Level Security (RLS)",
    "Soft delete implementation"
  ],
  "constraints": {
    "file_access": [
      "modules/*/api/migrations/**"
    ],
    "file_denied": [
      "**/*.go",
      "**/*.tsx"
    ],
    "dependencies": [
      "domain-spec-must-exist"
    ]
  },
  "scoring": {
    "rubric": "(CORRECTNESS×4 + QUALITY×3 + EFFICIENCY×2 + LEARNING×1) / 10",
    "baseline": 7,
    "rope_trigger": 4,
    "dimensions": {
      "correctness": "Does the output match the domain spec and requirements?",
      "quality": "Is the implementation clean, standard-compliant, and error-free?",
      "efficiency": "Is the solution optimal and avoiding unnecessary complexity?",
      "learning": "Were past patterns from the Experience Library correctly applied?"
    }
  },
  "team": "CODE",
  "layer": 2,
  "activation_tier": "BY_TASK_TYPE"
}