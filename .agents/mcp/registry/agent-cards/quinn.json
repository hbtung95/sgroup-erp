{
  "name": "QUINN",
  "description": "Testing Engineer — Frontend unit tests, E2E tests, domain edge cases",
  "version": "5.0",
  "url": "agent://sgroup-erp/quinn",
  "capabilities": {
    "tools_provided": [
      "quinn_create_unit_test",
      "quinn_create_e2e_test",
      "quinn_run_tests"
    ],
    "tools_consumed": [
      "test_frontend_module",
      "lint_frontend",
      "exp_search_trajectories",
      "domain_get_spec"
    ],
    "input_modes": [
      "text/markdown",
      "text/typescript"
    ],
    "output_modes": [
      "text/typescript"
    ]
  },
  "skills": [
    "Vitest unit testing",
    "React Testing Library",
    "Playwright E2E automation",
    "Financial edge case validation"
  ],
  "constraints": {
    "file_access": [
      "**/*.test.*",
      "**/*.spec.*",
      "e2e/**"
    ],
    "file_denied": [
      "**/api/**/*.go"
    ],
    "dependencies": [
      "domain-spec-must-exist"
    ]
  },
  "scoring": {
    "rubric": "(CORRECTNESS×4 + QUALITY×3 + EFFICIENCY×2 + LEARNING×1) / 10",
    "baseline": 7,
    "rope_trigger": 4,
    "dimensions": {
      "correctness": "Does the output match the domain spec and requirements?",
      "quality": "Is the implementation clean, standard-compliant, and error-free?",
      "efficiency": "Is the solution optimal and avoiding unnecessary complexity?",
      "learning": "Were past patterns from the Experience Library correctly applied?"
    }
  },
  "team": "SUPPORT",
  "layer": 2,
  "activation_tier": "BY_TASK_TYPE"
}