{
  "name": "@sgroup/mcp-infrastructure",
  "version": "1.0.0",
  "private": true,
  "description": "SGROUP ERP Multi-Agent MCP Infrastructure (HERA V5)",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "build:domain": "tsc --build servers/erp-domain-mcp-server",
